// Build8 Internal Business Management System
// PostgreSQL schema with RBAC, CRM, PM, Finance, and Founder Equity

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ClientStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
}

enum LeadStage {
  NEW
  CONTACTED
  MEETING_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum MeetingType {
  ON_SITE
  ONLINE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum PersonStatus {
  CANDIDATE
  ACTIVE
  ON_HOLD
  FREELANCER
  FORMER_MEMBER
}

enum CandidateStage {
  NEW
  CONTACTED
  INTERVIEW
  TECHNICAL_TEST
  ACCEPTED
  REJECTED
  HIRED
}

enum ExpenseCategory {
  MARKETING
  HOSTING
  DOMAINS
  SOFTWARE
  SALARIES
  OPERATIONS
  OTHER
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CREDIT_CARD
  PAYPAL
  WISE
  OTHER
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum DocumentCategory {
  CONTRACT
  CLIENT_FILE
  PROJECT_FILE
  TEAM_DOCUMENT
  CANDIDATE_CV
  OTHER
}

enum NotificationType {
  NEW_CLIENT
  NEW_PAYMENT
  NEW_CANDIDATE
  PROJECT_DEADLINE
  INVOICE_OVERDUE
  TASK_ASSIGNED
  SYSTEM
}

enum ActivityType {
  CLIENT_CREATED
  CLIENT_UPDATED
  LEAD_CREATED
  LEAD_STAGE_CHANGED
  PROJECT_CREATED
  PROJECT_UPDATED
  TASK_CREATED
  TASK_COMPLETED
  PAYMENT_RECEIVED
  EXPENSE_ADDED
  INVOICE_CREATED
  INVOICE_PAID
  CANDIDATE_ADDED
  TEAM_MEMBER_ADDED
  DOCUMENT_UPLOADED
  QUOTATION_SENT
  WITHDRAWAL_REQUESTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ============================================================
// AUTH & RBAC
// ============================================================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  status        UserStatus @default(ACTIVE)
  roleId        String
  role          Role       @relation(fields: [roleId], references: [id])
  personId      String?    @unique
  person        Person?    @relation(fields: [personId], references: [id])
  founderId     String?    @unique
  founder       Founder?   @relation(fields: [founderId], references: [id])

  accounts      Account[]
  sessions      Session[]
  notifications Notification[]
  activities    Activity[]     @relation("ActivityActor")
  documents     Document[]     @relation("DocumentUploader")
  comments      Comment[]
  tasksAssigned Task[]         @relation("TaskAssignee")
  tasksCreated  Task[]         @relation("TaskCreator")
  projectsLed   Project[]      @relation("ProjectLead")
  projectMembers ProjectMember[]
  clientNotes   ClientNote[]
  candidateNotes CandidateNote[]
  withdrawalRequests WithdrawalRequest[] @relation("WithdrawalRequester")
  withdrawalApprovals WithdrawalRequest[] @relation("WithdrawalApprover")
  meetingsAssigned   Meeting[]           @relation("MeetingAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([roleId])
  @@index([status])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  module      String
  action      String
  description String?
  roles       RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
  @@index([slug])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// CRM
// ============================================================

model Client {
  id            String       @id @default(cuid())
  companyName   String
  contactPerson String?
  email         String?
  phone         String?
  whatsapp      String?
  country       String?
  address       String?      @db.Text
  website       String?
  status        ClientStatus @default(LEAD)

  notes      ClientNote[]
  meetings   Meeting[]
  projects   Project[]
  revenues   Revenue[]
  quotations Quotation[]
  invoices   Invoice[]
  documents  Document[]
  leads      Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyName])
  @@index([status])
  @@index([email])
  @@map("clients")
}

model ClientNote {
  id       String @id @default(cuid())
  clientId String
  authorId String
  content  String @db.Text
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("client_notes")
}

model Meeting {
  id              String      @id @default(cuid())
  clientId        String
  title           String
  description     String?     @db.Text
  date            DateTime
  type            MeetingType @default(ON_SITE)
  location        String?
  onlinePlatform  String?
  meetingLink     String?
  attendees       String?
  assignedToId    String?
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo   User?    @relation("MeetingAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([date])
  @@index([assignedToId])
  @@map("meetings")
}

model Lead {
  id        String    @id @default(cuid())
  name      String
  company   String?
  email     String?
  phone     String?
  source    String?
  stage     LeadStage @default(NEW)
  notes     String?   @db.Text
  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([email])
  @@map("leads")
}

// ============================================================
// PROJECT MANAGEMENT
// ============================================================

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  clientId    String
  leadId      String?
  startDate   DateTime?
  deadline    DateTime?
  budget      Decimal?      @db.Decimal(12, 2)
  status      ProjectStatus @default(PLANNING)

  client   Client          @relation(fields: [clientId], references: [id])
  lead     User?           @relation("ProjectLead", fields: [leadId], references: [id])
  members  ProjectMember[]
  tasks    Task[]
  comments Comment[]
  revenues Revenue[]
  quotations Quotation[]
  invoices Invoice[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([deadline])
  @@map("projects")
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  projectId   String?
  assigneeId  String?
  creatorId   String
  position    Int          @default(0)

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User      @relation("TaskCreator", fields: [creatorId], references: [id])
  subtasks Subtask[]
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

model Subtask {
  id        String     @id @default(cuid())
  taskId    String
  title     String
  completed Boolean    @default(false)
  position  Int        @default(0)
  task      Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@map("subtasks")
}

model Comment {
  id        String  @id @default(cuid())
  content   String  @db.Text
  authorId  String
  projectId String?
  taskId    String?
  author    User    @relation(fields: [authorId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([taskId])
  @@map("comments")
}

// ============================================================
// PEOPLE
// ============================================================

model Person {
  id               String       @id @default(cuid())
  fullName         String
  profilePhoto     String?
  email            String?      @unique
  phone            String?
  whatsapp         String?
  address          String?      @db.Text
  position         String?
  yearsExperience  Int?
  portfolioUrl     String?
  linkedinUrl      String?
  githubUrl        String?
  availability     String?
  expectedSalary   Decimal?     @db.Decimal(12, 2)
  currentSalary    Decimal?     @db.Decimal(12, 2)
  joiningDate      DateTime?
  status           PersonStatus @default(CANDIDATE)

  user     User?
  skills   PersonSkill[]
  candidate Candidate?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@index([status])
  @@index([email])
  @@map("people")
}

model Skill {
  id    String        @id @default(cuid())
  name  String        @unique
  people PersonSkill[]

  createdAt DateTime @default(now())

  @@map("skills")
}

model PersonSkill {
  personId String
  skillId  String
  level    Int      @default(1)
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([personId, skillId])
  @@map("person_skills")
}

model Candidate {
  id              String         @id @default(cuid())
  personId        String         @unique
  cvUrl           String?
  experienceLevel String?
  stage           CandidateStage @default(NEW)
  interviewNotes  String?        @db.Text
  testResults     String?        @db.Text

  person Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  notes  CandidateNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@map("candidates")
}

model CandidateNote {
  id          String    @id @default(cuid())
  candidateId String
  authorId    String
  content     String    @db.Text
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId])
  @@map("candidate_notes")
}

// ============================================================
// FINANCE
// ============================================================

model Revenue {
  id            String        @id @default(cuid())
  projectId     String?
  clientId      String
  amount        Decimal       @db.Decimal(12, 2)
  date          DateTime
  paymentMethod PaymentMethod @default(BANK_TRANSFER)
  description   String?
  isAdvance     Boolean       @default(false)

  project Project? @relation(fields: [projectId], references: [id])
  client  Client   @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([date])
  @@map("revenues")
}

model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([date])
  @@map("expenses")
}

// ============================================================
// FOUNDER EQUITY
// ============================================================

model Founder {
  id             String  @id @default(cuid())
  name           String
  email          String  @unique
  equityPercent  Decimal @db.Decimal(5, 2)

  user                User?
  distributions       EquityDistribution[]
  withdrawalRequests  WithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("founders")
}

model EquityDistribution {
  id              String  @id @default(cuid())
  founderId       String?
  periodStart     DateTime
  periodEnd       DateTime
  totalRevenue    Decimal @db.Decimal(12, 2)
  totalExpenses   Decimal @db.Decimal(12, 2)
  netProfit       Decimal @db.Decimal(12, 2)
  founderShare    Decimal @db.Decimal(12, 2)
  reserveShare    Decimal @db.Decimal(12, 2)
  isReserve       Boolean @default(false)
  notes           String?

  founder Founder? @relation(fields: [founderId], references: [id])

  createdAt DateTime @default(now())

  @@index([periodStart, periodEnd])
  @@index([founderId])
  @@map("equity_distributions")
}

model WithdrawalRequest {
  id          String           @id @default(cuid())
  founderId   String
  requesterId String
  approverId  String?
  amount      Decimal          @db.Decimal(12, 2)
  status      WithdrawalStatus @default(PENDING)
  notes       String?

  founder   Founder @relation(fields: [founderId], references: [id])
  requester User    @relation("WithdrawalRequester", fields: [requesterId], references: [id])
  approver  User?   @relation("WithdrawalApprover", fields: [approverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([founderId])
  @@index([status])
  @@map("withdrawal_requests")
}

// ============================================================
// QUOTATIONS & INVOICES
// ============================================================

model Quotation {
  id          String          @id @default(cuid())
  number      String          @unique
  clientId    String
  projectId   String?
  title       String
  scope       String?         @db.Text
  subtotal    Decimal         @db.Decimal(12, 2)
  tax         Decimal         @default(0) @db.Decimal(12, 2)
  total       Decimal         @db.Decimal(12, 2)
  status      QuotationStatus @default(DRAFT)
  validUntil  DateTime?
  notes       String?         @db.Text

  client  Client          @relation(fields: [clientId], references: [id])
  project Project?        @relation(fields: [projectId], references: [id])
  items   QuotationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

model Invoice {
  id        String        @id @default(cuid())
  number    String        @unique
  clientId  String
  projectId String?
  subtotal  Decimal       @db.Decimal(12, 2)
  tax       Decimal       @default(0) @db.Decimal(12, 2)
  total     Decimal       @db.Decimal(12, 2)
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?       @db.Text

  client  Client        @relation(fields: [clientId], references: [id])
  project Project?      @relation(fields: [projectId], references: [id])
  items   InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id          String           @id @default(cuid())
  name        String
  description String?
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  category    DocumentCategory @default(OTHER)
  tags        String[]
  folderPath  String           @default("/")
  clientId    String?
  projectId   String?
  uploaderId  String

  client   Client?  @relation(fields: [clientId], references: [id])
  project  Project? @relation(fields: [projectId], references: [id])
  uploader User     @relation("DocumentUploader", fields: [uploaderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([clientId])
  @@index([projectId])
  @@index([folderPath])
  @@map("documents")
}

// ============================================================
// NOTIFICATIONS & ACTIVITY
// ============================================================

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  message String
  link    String?
  read    Boolean          @default(false)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  metadata    Json?
  actorId     String?
  actor       User?        @relation("ActivityActor", fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@map("activities")
}

// ============================================================
// SETTINGS
// ============================================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  updatedAt DateTime @updatedAt

  @@map("settings")
}
