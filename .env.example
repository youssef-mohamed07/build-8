# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Database (from Supabase Dashboard → Settings → Database)
# Find your region in Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Build8"

# Development: bypass login and RBAC via env (never enable in production)
# Or use "Skip auth" button on login screen (sets cookie, dev only)
SKIP_AUTH="false"

# Founders (after db:seed):
# youssef@build8.com / Build8@2026
# saif@build8.com / Build8@2026

# Email (for password reset)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@build8.com"

# File Storage (S3-compatible)
# S3_BUCKET="build8-documents"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
