# Database (Supabase pooler)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Auth.js — use localhost locally; on Vercel set to your production domain
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Build8"

# Vercel production example:
# AUTH_URL="https://system.build8.dev"
# NEXT_PUBLIC_APP_URL="https://system.build8.dev"

# Skip login: use "Skip auth" on /login (works in production via cookie).
# Or set both to "true" to bypass login entirely (optional on Vercel).
SKIP_AUTH="false"
NEXT_PUBLIC_SKIP_AUTH="false"
