# Database (Supabase pooler)
# App runtime (Vercel + local dev) — Transaction pooler, port 6543
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations + seed — Session/direct pooler, port 5432
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Auth.js — REQUIRED on Vercel or login will fail
# Generate: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Build8"

# Vercel production (all required):
# AUTH_SECRET="<openssl rand -base64 32>"
# AUTH_URL="https://system.build8.dev"
# NEXT_PUBLIC_APP_URL="https://system.build8.dev"
# DATABASE_URL="<supabase pooler url>"
# DIRECT_URL="<supabase direct url>"

# Skip login: use "Skip auth" on /login (works in production via cookie).
# Or set both to "true" to bypass login entirely (optional on Vercel).
SKIP_AUTH="false"
NEXT_PUBLIC_SKIP_AUTH="false"

# Test accounts (after npm run db:seed):
# youssef@build8.com / Build8@2026 (founder)
# saif@build8.com / Build8@2026 (founder)
# test@build8.com / Build8@2026 (admin)
